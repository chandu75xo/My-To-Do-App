# .env.example
#
# What is a .env file?
# A plain text file that stores SECRET values your app needs but must NEVER
# be committed to GitHub (passwords, API keys, etc).
#
# How it works:
#   1. Copy this file → rename it to just ".env"
#   2. Fill in your real values
#   3. python-dotenv reads it and makes each line available as an environment variable
#   4. .env is listed in .gitignore so it never gets pushed to GitHub
#
# How to use in Python:
#   from dotenv import load_dotenv
#   import os
#   load_dotenv()
#   secret = os.getenv('JWT_SECRET_KEY')

# ── Flask ─────────────────────────────────────────────────────────────────────
# SECRET_KEY: Flask uses this to sign session cookies. Make it long and random.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used to sign JWT tokens. Different from SECRET_KEY. Also make it long and random.
JWT_SECRET_KEY=replace-with-another-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: SQLite (no setup needed — creates a file automatically)
DATABASE_URL=sqlite:///todo.db

# Production (uncomment and fill in when you switch to MySQL on Render/PlanetScale):
# DATABASE_URL=mysql+pymysql://username:password@host:3306/database_name

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# MAIL_USERNAME: your Gmail address
# MAIL_PASSWORD: NOT your regular Gmail password — use an App Password:
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
#   2. Create one for "Mail" → copy the 16-char code here
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── Environment ───────────────────────────────────────────────────────────────
# FLASK_ENV=development enables debug mode (auto-reload, detailed errors)
# Change to "production" when deploying to Render.com
FLASK_ENV=development
