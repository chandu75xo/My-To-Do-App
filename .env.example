# .env.example — frontend environment variables
# Copy this to .env.local for local dev
# On Netlify, add VITE_API_URL in Site Settings → Environment Variables

# Local development (Flask running on your machine)
VITE_API_URL=http://localhost:5000

# Production (uncomment and set to your Render URL after deployment)
# VITE_API_URL=https://done-todo-api.onrender.com
